<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    android:gravity="center"
    android:padding="28dp">

    <ImageView
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:src="@drawable/ic_stream_large"
        android:layout_marginBottom="28dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Live Audio Stream"
        android:textColor="@color/white"
        android:textSize="26sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="10dp" />

    <TextView
        android:id="@+id/stream_status"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ready"
        android:textColor="@color/accent_green"
        android:textSize="15sp"
        android:gravity="center"
        android:layout_marginBottom="44dp" />

    <Button
        android:id="@+id/start_stream_btn"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="▶  Start Stream"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:background="@drawable/btn_primary"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/stop_stream_btn"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="⏹  Stop"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:background="@drawable/btn_danger" />
</LinearLayout>
