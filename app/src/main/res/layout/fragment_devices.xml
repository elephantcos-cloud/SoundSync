<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_dark"
    android:padding="20dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nearby Devices"
        android:textColor="@color/white"
        android:textSize="26sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <TextView
        android:id="@+id/status_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Tap Scan to discover"
        android:textColor="@color/text_secondary"
        android:textSize="14sp"
        android:layout_marginBottom="16dp" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="10dp">
        <Button android:id="@+id/scan_btn" android:layout_width="0dp" android:layout_height="52dp"
            android:layout_weight="1" android:text="Scan" android:textColor="@color/white"
            android:background="@drawable/btn_primary" android:layout_marginEnd="8dp" />
        <Button android:id="@+id/disconnect_btn" android:layout_width="0dp" android:layout_height="52dp"
            android:layout_weight="1" android:text="Disconnect" android:textColor="@color/white"
            android:background="@drawable/btn_danger" />
    </LinearLayout>

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:layout_marginBottom="16dp">
        <Button android:id="@+id/show_qr_btn" android:layout_width="0dp" android:layout_height="52dp"
            android:layout_weight="1" android:text="My QR Code" android:textColor="@color/white"
            android:background="@drawable/btn_secondary" android:layout_marginEnd="8dp" />
        <Button android:id="@+id/scan_qr_btn" android:layout_width="0dp" android:layout_height="52dp"
            android:layout_weight="1" android:text="Scan QR" android:textColor="@color/white"
            android:background="@drawable/btn_secondary" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/device_list"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />
</LinearLayout>
